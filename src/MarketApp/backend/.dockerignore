# Ignore virtual environments
venv/
venv310/
.venv/

# Ignore Python cache
__pycache__/
*.pyc

# Ignore Git
.git/
.gitignore

# Ignore training outputs
logs/
checkpoints/
datasets/
data/

# Ignore OS junk
.DS_Store
Thumbs.db

# Ignore frontend
../frontend/

# Ignore model and training artifacts by default
*.pt
**/*.pkl
*.csv

