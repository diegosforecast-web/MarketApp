from __future__ import annotations

import logging
from datetime import date, datetime, time, timezone
from typing import Any

from services.market_data_service import MarketDataService
from services.supabase_service import SupabaseService


logger = logging.getLogger(__name__)


class PredictionVerificationService:
    MARKET_CLOSE_UTC = time(hour=21, minute=15)

    def __init__(self) -> None:
        self.market_data = MarketDataService()
        self.supabase = SupabaseService()

    @staticmethod
    def _parse_date(value: Any) -> date | None:
        if not value:
            return None

        if isinstance(value, date) and not isinstance(value, datetime):
            return value

        return datetime.fromisoformat(
            str(value).replace("Z", "+00:00")
        ).date()

    @classmethod
    def _target_date(
        cls,
        row: dict[str, Any],
    ) -> date | None:
        direct = cls._parse_date(row.get("target_date"))

        if direct:
            return direct

        response = row.get("response_json") or {}
        trajectory = response.get("trajectory") or []

        if not trajectory:
            return None

        return cls._parse_date(
            trajectory[-1].get("date")
        )

    @staticmethod
    def _direction_correct(
        predicted_move_pct: float,
        actual_move_pct: float,
    ) -> bool:
        if predicted_move_pct > 0:
            return actual_move_pct > 0

        if predicted_move_pct < 0:
            return actual_move_pct < 0

        return abs(actual_move_pct) < 0.10

    @staticmethod
    def _price_accuracy(
        forecast_price: float,
        actual_price: float,
    ) -> float:
        if actual_price <= 0:
            return 0.0

        error_pct = (
            abs(forecast_price - actual_price)
            / actual_price
            * 100
        )

        return max(
            0.0,
            min(100.0, 100.0 - error_pct),
        )

    @classmethod
    def _target_is_ready(
        cls,
        target_date: date,
    ) -> bool:
        now = datetime.now(timezone.utc)

        if target_date < now.date():
            return True

        if target_date > now.date():
            return False

        return now.time() >= cls.MARKET_CLOSE_UTC

    def verify_row(
        self,
        row: dict[str, Any],
    ) -> dict[str, Any] | None:
        target_date = self._target_date(row)

        if target_date is None:
            logger.warning(
                "Prediction %s has no target date.",
                row.get("id"),
            )
            return None

        if not self._target_is_ready(target_date):
            return None

        response = row.get("response_json") or {}

        ticker = str(
            row.get("ticker")
            or response.get("ticker")
            or ""
        ).strip().upper()

        if not ticker:
            logger.warning(
                "Prediction %s has no ticker.",
                row.get("id"),
            )
            return None

        history = self.market_data.get_history(ticker)

        eligible = history[
            history["date"].dt.date >= target_date
        ]

        if eligible.empty:
            self.supabase.update_prediction_verification(
                prediction_id=row["id"],
                payload={
                    "verification_status": "due",
                },
            )
            return None

        actual_row = eligible.iloc[0]
        actual_date = actual_row["date"].date()
        actual_price = float(actual_row["close"])

        current_price = float(
            response.get("current_price") or 0
        )
        forecast_price = float(
            response.get("forecast_price") or 0
        )

        predicted_move_pct = float(
            row.get("expected_move_pct")
            if row.get("expected_move_pct") is not None
            else response.get("expected_move_pct") or 0
        )

        if current_price <= 0 or forecast_price <= 0:
            logger.warning(
                "Prediction %s has invalid stored prices.",
                row.get("id"),
            )
            return None

        actual_move_pct = (
            actual_price / current_price - 1
        ) * 100

        payload = {
            "verification_status": "verified",
            "actual_price": round(actual_price, 4),
            "actual_move_pct": round(
                actual_move_pct,
                4,
            ),
            "direction_correct": self._direction_correct(
                predicted_move_pct,
                actual_move_pct,
            ),
            "price_accuracy_pct": round(
                self._price_accuracy(
                    forecast_price,
                    actual_price,
                ),
                2,
            ),
            "verified_at": datetime.now(
                timezone.utc
            ).isoformat(),
            "target_date": actual_date.isoformat(),
        }

        return self.supabase.update_prediction_verification(
            prediction_id=row["id"],
            payload=payload,
        )

    def verify_due_for_user(
        self,
        *,
        user_id: str,
        limit: int = 50,
    ) -> dict[str, int]:
        rows = self.supabase.list_verifiable_predictions(
            user_id=user_id,
            today=datetime.now(timezone.utc).date(),
            limit=limit,
        )

        verified = 0
        waiting = 0
        failed = 0

        for row in rows:
            try:
                if self.verify_row(row):
                    verified += 1
                else:
                    waiting += 1

            except Exception:
                failed += 1

                logger.exception(
                    "Verification failed for prediction %s.",
                    row.get("id"),
                )

        return {
            "checked": len(rows),
            "verified": verified,
            "waiting_for_market_data": waiting,
            "failed": failed,
        }