from __future__ import annotations

import os
from datetime import date, datetime
from typing import Any

from dotenv import load_dotenv
from supabase import create_client


load_dotenv()


class SupabaseService:
    def __init__(self):
        url = os.getenv("SUPABASE_URL")
        key = os.getenv("SUPABASE_SERVICE_ROLE_KEY")

        if not url:
            raise RuntimeError("SUPABASE_URL is not set.")

        if not key:
            raise RuntimeError(
                "SUPABASE_SERVICE_ROLE_KEY is not set."
            )

        self.client = create_client(url, key)

    @staticmethod
    def _profile_columns() -> str:
        return (
            "id,email,plan,subscription_status,current_period_start,"
            "current_period_end,created_at,stripe_customer_id,"
            "stripe_subscription_id,stripe_price_id"
        )

    def get_plan_by_email(self, email: str) -> str:
        result = (
            self.client.table("profiles")
            .select("plan")
            .eq("email", email)
            .limit(1)
            .execute()
        )

        if not result.data:
            return "free"

        return result.data[0].get("plan", "free")

    def get_profile(
        self,
        user_id: str,
    ) -> dict[str, Any] | None:
        result = (
            self.client.table("profiles")
            .select(self._profile_columns())
            .eq("id", user_id)
            .maybe_single()
            .execute()
        )

        return result.data

    def update_plan_by_email(
        self,
        email: str,
        plan: str,
        stripe_customer_id: str | None = None,
        stripe_subscription_id: str | None = None,
        stripe_price_id: str | None = None,
        subscription_status: str = "active",
        current_period_start: str | None = None,
        current_period_end: str | None = None,
    ) -> None:
        payload: dict[str, Any] = {
            "email": email,
            "plan": plan,
            "subscription_status": subscription_status,
        }

        if stripe_customer_id:
            payload["stripe_customer_id"] = stripe_customer_id

        if stripe_subscription_id:
            payload[
                "stripe_subscription_id"
            ] = stripe_subscription_id

        if stripe_price_id:
            payload["stripe_price_id"] = stripe_price_id

        if current_period_start:
            payload[
                "current_period_start"
            ] = current_period_start

        if current_period_end:
            payload[
                "current_period_end"
            ] = current_period_end

        existing = (
            self.client.table("profiles")
            .select("id,email")
            .eq("email", email)
            .limit(1)
            .execute()
        )

        if existing.data:
            (
                self.client.table("profiles")
                .update(payload)
                .eq("id", existing.data[0]["id"])
                .execute()
            )
            return

        self.client.table("profiles").insert(payload).execute()

    def update_subscription_by_user_id(
        self,
        *,
        user_id: str,
        plan: str,
        subscription_status: str,
        stripe_customer_id: str | None,
        stripe_subscription_id: str | None,
        stripe_price_id: str | None,
        current_period_start: str | None,
        current_period_end: str | None,
    ) -> bool:
        result = (
            self.client.table("profiles")
            .update(
                {
                    "plan": plan,
                    "subscription_status": subscription_status,
                    "stripe_customer_id": stripe_customer_id,
                    "stripe_subscription_id": stripe_subscription_id,
                    "stripe_price_id": stripe_price_id,
                    "current_period_start": current_period_start,
                    "current_period_end": current_period_end,
                }
            )
            .eq("id", user_id)
            .execute()
        )

        return bool(result.data)

    def update_subscription_by_customer_id(
        self,
        *,
        stripe_customer_id: str,
        plan: str,
        subscription_status: str,
        stripe_subscription_id: str | None,
        stripe_price_id: str | None,
        current_period_start: str | None,
        current_period_end: str | None,
    ) -> bool:
        result = (
            self.client.table("profiles")
            .update(
                {
                    "plan": plan,
                    "subscription_status": subscription_status,
                    "stripe_subscription_id": stripe_subscription_id,
                    "stripe_price_id": stripe_price_id,
                    "current_period_start": current_period_start,
                    "current_period_end": current_period_end,
                }
            )
            .eq(
                "stripe_customer_id",
                stripe_customer_id,
            )
            .execute()
        )

        return bool(result.data)

    def is_stripe_event_processed(
        self,
        event_id: str,
    ) -> bool:
        result = (
            self.client.table("stripe_webhook_events")
            .select("event_id")
            .eq("event_id", event_id)
            .limit(1)
            .execute()
        )
        if result is None:
            return False

        return bool(result.data)

    def record_stripe_event(
        self,
        *,
        event_id: str,
        event_type: str,
    ) -> None:
        (
            self.client.table("stripe_webhook_events")
            .insert(
                {
                    "event_id": event_id,
                    "event_type": event_type,
                }
            )
            .execute()
        )

    def insert_prediction(
        self,
        *,
        user_id: str,
        payload: dict[str, Any],
    ) -> dict[str, Any]:
        trajectory = payload.get("trajectory") or []
        target_date = (
            trajectory[-1].get("date")
            if trajectory
            else None
        )

        result = (
            self.client.table("predictions")
            .insert(
                {
                    "user_id": user_id,
                    "ticker": payload["ticker"],
                    "horizon": int(payload["horizon"]),
                    "recommendation": payload.get(
                        "recommendation"
                    ),
                    "confidence": payload.get("confidence"),
                    "expected_move_pct": payload.get(
                        "expected_move_pct"
                    ),
                    "response_json": payload,
                    "target_date": target_date,
                    "verification_status": "pending",
                }
            )
            .execute()
        )

        if not result.data:
            raise RuntimeError(
                "Supabase did not return the saved prediction."
            )

        return result.data[0]

    def insert_usage(
        self,
        *,
        user_id: str,
        horizon: int,
    ) -> None:
        (
            self.client.table("prediction_usage")
            .insert(
                {
                    "user_id": user_id,
                    "horizon": horizon,
                }
            )
            .execute()
        )

    def count_usage(
        self,
        *,
        user_id: str,
        horizon: int | None = None,
        created_at_gte: datetime | None = None,
        created_at_lt: datetime | None = None,
    ) -> int:
        query = (
            self.client.table("prediction_usage")
            .select("id", count="exact")
            .eq("user_id", user_id)
        )

        if horizon is not None:
            query = query.eq("horizon", int(horizon))

        if created_at_gte is not None:
            query = query.gte(
                "created_at",
                created_at_gte.isoformat(),
            )

        if created_at_lt is not None:
            query = query.lt(
                "created_at",
                created_at_lt.isoformat(),
            )

        result = query.execute()
        return result.count or 0

    @staticmethod
    def _prediction_columns() -> str:
        return (
            "id,user_id,ticker,horizon,recommendation,confidence,"
            "expected_move_pct,response_json,created_at,target_date,"
            "verification_status,actual_price,actual_move_pct,"
            "direction_correct,price_accuracy_pct,verified_at"
        )

    def list_predictions(
        self,
        *,
        user_id: str,
        limit: int = 50,
    ) -> list[dict[str, Any]]:
        result = (
            self.client.table("predictions")
            .select(self._prediction_columns())
            .eq("user_id", user_id)
            .order("created_at", desc=True)
            .limit(limit)
            .execute()
        )

        return result.data or []

    def get_prediction(
        self,
        *,
        user_id: str,
        prediction_id: str,
    ) -> dict[str, Any] | None:
        result = (
            self.client.table("predictions")
            .select(self._prediction_columns())
            .eq("user_id", user_id)
            .eq("id", prediction_id)
            .maybe_single()
            .execute()
        )

        return result.data

    def list_verifiable_predictions(
        self,
        *,
        user_id: str,
        today: date,
        limit: int = 50,
    ) -> list[dict[str, Any]]:
        result = (
            self.client.table("predictions")
            .select(self._prediction_columns())
            .eq("user_id", user_id)
            .in_(
                "verification_status",
                ["pending", "due"],
            )
            .lte("target_date", today.isoformat())
            .order("target_date", desc=False)
            .limit(limit)
            .execute()
        )

        return result.data or []

    def update_prediction_verification(
        self,
        *,
        prediction_id: str,
        payload: dict[str, Any],
    ) -> dict[str, Any]:
        result = (
            self.client.table("predictions")
            .update(payload)
            .eq("id", prediction_id)
            .execute()
        )

        if not result.data:
            raise RuntimeError(
                "Prediction verification update failed."
            )

        return result.data[0]
