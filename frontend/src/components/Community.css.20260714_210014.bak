.community-section{border:1px solid rgba(89,225,255,.2);border-radius:26px;background:rgba(5,11,38,.76);box-shadow:0 0 34px rgba(0,210,255,.08),inset 0 0 24px rgba(139,61,255,.035);padding:30px;backdrop-filter:blur(20px)}
.community-heading{align-items:flex-start}.community-heading p{max-width:760px;margin:9px 0 0;color:#8fb2bd;line-height:1.6}.community-state,.community-message{display:flex;align-items:center;justify-content:center;gap:10px;margin-top:18px;border-radius:15px;padding:14px}.community-state{border:1px dashed rgba(89,225,255,.2);color:#9dc4cd}.community-message-error{border:1px solid rgba(248,113,113,.3);background:rgba(248,113,113,.08);color:#fecaca}.community-message-success{border:1px solid rgba(74,222,128,.28);background:rgba(74,222,128,.08);color:#a7f3d0}.community-spinner{animation:community-spin .8s linear infinite}@keyframes community-spin{to{transform:rotate(360deg)}}
.community-overview-grid,.community-form-grid{display:grid;grid-template-columns:.8fr 1.2fr;gap:16px;margin-top:22px}.community-rating-card,.community-mission-card,.community-form-card,.community-list-section{border:1px solid rgba(89,225,255,.14);border-radius:20px;background:rgba(3,10,32,.62);padding:22px}.community-rating-card>strong{display:block;margin-top:8px;color:#fff;font-size:2rem}.community-rating-card>p,.community-mission-card p{color:#8eafb9;line-height:1.55}.community-mission-card{display:flex;gap:14px;background:radial-gradient(circle at 100% 0,rgba(139,61,255,.11),transparent 42%),rgba(3,10,32,.62)}.community-mission-card>svg{flex:0 0 auto;color:#68e7f7}.community-mission-card h3{margin:0;color:#fff;font-size:1.35rem}
.community-form-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.community-form-heading{display:flex;gap:11px;margin-bottom:18px}.community-form-heading>svg{flex:0 0 auto;color:#68e7f7}.community-form-heading h3{margin:0;color:#fff}.community-form-heading p{margin:5px 0 0;color:#7f9fa9;font-size:.84rem}.community-form-card{display:grid;align-content:start;gap:14px}.community-form-card label{display:grid;gap:8px;color:#c8f3fb;font-size:.82rem;font-weight:800}.community-form-card input,.community-form-card textarea{width:100%;border:1px solid rgba(82,221,255,.2);border-radius:13px;outline:0;background:rgba(2,8,29,.78);color:#fff;padding:13px 14px;resize:vertical}.community-form-card input:focus,.community-form-card textarea:focus{border-color:rgba(82,221,255,.58);box-shadow:0 0 16px rgba(0,211,255,.08)}.community-consent-row{display:flex!important;align-items:center;gap:9px!important;color:#a9cbd3!important;font-weight:600!important}.community-consent-row input{width:auto}.community-form-card>button{display:flex;min-height:50px;align-items:center;justify-content:center;gap:9px;border:0;border-radius:13px;background:linear-gradient(90deg,#00cceb,#873dff);color:#fff;font-weight:900}.community-form-card>button:disabled,.feature-vote-button:disabled{cursor:wait;opacity:.65}
.community-stars{display:flex;gap:4px;margin-top:8px;color:#f7d85d}.community-stars button{display:grid;border:0;background:transparent;color:#516d77;padding:2px;place-items:center}.community-stars button:not(:disabled):hover,.community-stars .community-star-active{color:#f7d85d}
.community-list-section{margin-top:16px}.community-subheading{display:flex;align-items:center;justify-content:space-between;gap:18px}.community-subheading h3{margin:0;color:#fff}.community-subheading>svg{color:#68e7f7}.feature-request-list,.community-roadmap-grid,.community-review-grid{display:grid;gap:12px;margin-top:18px}.feature-request-list>article{display:grid;grid-template-columns:1fr auto;gap:16px;border:1px solid rgba(89,225,255,.11);border-radius:16px;background:rgba(0,211,255,.025);padding:17px}.feature-request-list h4,.community-roadmap-grid h4,.community-review-grid h4{margin:10px 0 7px;color:#fff}.feature-request-list p,.community-roadmap-grid p,.community-review-grid p{margin:0;color:#8eafb9;line-height:1.5}.feature-vote-button{display:flex;min-width:74px;height:42px;align-items:center;justify-content:center;gap:7px;border:1px solid rgba(89,225,255,.18);border-radius:12px;background:rgba(0,211,255,.05);color:#a8dbe4;font-weight:900}.feature-vote-active{border-color:rgba(74,222,128,.3);background:rgba(74,222,128,.09);color:#86efac}.community-roadmap-grid,.community-review-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.community-roadmap-grid>article,.community-review-grid>article{border:1px solid rgba(89,225,255,.11);border-radius:16px;background:rgba(0,211,255,.025);padding:17px}.community-review-grid>article>span{display:block;margin-top:14px;color:#68e7f7;font-size:.78rem;font-weight:800}.community-status{display:inline-flex;width:fit-content;border-radius:999px;padding:6px 9px;font-size:.66rem;font-weight:900;text-transform:uppercase}.community-status-submitted,.community-status-planned{background:rgba(96,216,255,.09);color:#83e6f6}.community-status-in_progress{background:rgba(250,204,21,.1);color:#fde68a}.community-status-completed{background:rgba(74,222,128,.1);color:#86efac}.community-status-declined{background:rgba(248,113,113,.1);color:#fca5a5}.community-empty{border:1px dashed rgba(89,225,255,.18);border-radius:15px;color:#789ba5;padding:24px;text-align:center}
@media(max-width:1000px){.community-overview-grid,.community-form-grid,.community-roadmap-grid,.community-review-grid{grid-template-columns:1fr}}@media(max-width:580px){.community-section{padding:22px 18px}.community-heading,.community-subheading{align-items:flex-start;flex-direction:column}.feature-request-list>article{grid-template-columns:1fr}.feature-vote-button{width:100%}}
