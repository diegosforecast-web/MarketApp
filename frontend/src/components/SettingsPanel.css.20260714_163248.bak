.settings-panel {
  border: 1px solid rgba(89, 225, 255, .2);
  border-radius: 26px;
  background: rgba(5, 11, 38, .76);
  box-shadow:
    0 0 34px rgba(0, 210, 255, .08),
    inset 0 0 24px rgba(139, 61, 255, .035);
  padding: 30px;
  backdrop-filter: blur(20px);
}

.settings-heading {
  align-items: flex-start;
}

.settings-heading p {
  max-width: 680px;
  margin: 9px 0 0;
  color: #8fb2bd;
  line-height: 1.55;
}

.settings-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 15px;
  margin-top: 24px;
}

.settings-card {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  align-items: center;
  gap: 14px;
  border: 1px solid rgba(89, 225, 255, .14);
  border-radius: 18px;
  background: rgba(3, 10, 32, .62);
  padding: 18px;
}

.settings-card-icon {
  display: grid;
  width: 44px;
  height: 44px;
  border-radius: 13px;
  background: rgba(0, 211, 255, .09);
  color: #67e6f7;
  place-items: center;
}

.settings-card-copy span,
.settings-card-copy strong,
.settings-card-copy small {
  display: block;
}

.settings-card-copy span {
  color: #83aab5;
  font-size: .72rem;
  font-weight: 800;
  text-transform: uppercase;
}

.settings-card-copy strong {
  margin-top: 6px;
  color: #fff;
  font-size: 1.05rem;
}

.settings-card-copy small {
  margin-top: 5px;
  color: #7899a4;
  line-height: 1.35;
}

.settings-card button {
  min-height: 42px;
  border: 1px solid rgba(89, 225, 255, .2);
  border-radius: 12px;
  background: rgba(0, 211, 255, .07);
  color: #c9f7fc;
  padding: 0 13px;
  font-weight: 800;
  white-space: nowrap;
}

.settings-card button:hover:not(:disabled) {
  border-color: rgba(89, 225, 255, .4);
  background: rgba(0, 211, 255, .12);
}

.settings-card button:disabled {
  cursor: wait;
  opacity: .65;
}

.settings-card-danger {
  border-color: rgba(248, 113, 113, .18);
}

.settings-card-danger .settings-card-icon {
  background: rgba(248, 113, 113, .09);
  color: #fca5a5;
}

.settings-card-danger button {
  border-color: rgba(248, 113, 113, .24);
  background: rgba(248, 113, 113, .07);
  color: #fecaca;
}

.settings-account-summary {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 13px;
  margin-top: 18px;
}

.settings-account-summary > div {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 4px 10px;
  border: 1px solid rgba(89, 225, 255, .11);
  border-radius: 15px;
  background: rgba(0, 211, 255, .035);
  padding: 15px;
}

.settings-account-summary svg {
  grid-row: 1 / 3;
  color: #67e6f7;
}

.settings-account-summary span {
  color: #7ea4af;
  font-size: .72rem;
  font-weight: 800;
  text-transform: uppercase;
}

.settings-account-summary strong {
  color: #fff;
  overflow-wrap: anywhere;
}

.settings-message,
.settings-error {
  display: flex;
  align-items: center;
  gap: 9px;
  margin-top: 16px;
  border-radius: 13px;
  padding: 12px 14px;
}

.settings-message {
  border: 1px solid rgba(74, 222, 128, .24);
  background: rgba(74, 222, 128, .07);
  color: #a7f3d0;
}

.settings-error {
  border: 1px solid rgba(248, 113, 113, .3);
  background: rgba(248, 113, 113, .08);
  color: #fecaca;
}

@media (max-width: 1000px) {
  .settings-grid {
    grid-template-columns: 1fr;
  }

  .settings-account-summary {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 650px) {
  .settings-panel {
    padding: 22px 18px;
  }

  .settings-card {
    grid-template-columns: auto 1fr;
  }

  .settings-card button {
    grid-column: 1 / -1;
    width: 100%;
  }
}
