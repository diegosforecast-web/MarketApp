.prediction-history-section {
  border: 1px solid rgba(89, 225, 255, .2);
  border-radius: 26px;
  background: rgba(5, 11, 38, .76);
  box-shadow:
    0 0 34px rgba(0, 210, 255, .08),
    inset 0 0 24px rgba(139, 61, 255, .035);
  padding: 30px;
  backdrop-filter: blur(20px);
}

.history-section-heading {
  align-items: flex-start;
}

.history-section-description {
  max-width: 720px;
  margin: 8px 0 0;
  color: #8fb2bd;
  line-height: 1.6;
}

.history-heading-actions {
  display: flex;
  align-items: center;
  gap: 14px;
}

.history-verify-button {
  display: inline-flex;
  min-height: 46px;
  align-items: center;
  justify-content: center;
  gap: 9px;
  border: 1px solid rgba(89, 225, 255, .22);
  border-radius: 13px;
  background: rgba(0, 211, 255, .07);
  color: #c9f7fc;
  padding: 0 15px;
  font-weight: 800;
}

.history-verify-button:hover:not(:disabled) {
  border-color: rgba(89, 225, 255, .42);
  background: rgba(0, 211, 255, .12);
}

.history-verify-button:disabled {
  cursor: wait;
  opacity: .7;
}

.history-performance-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14px;
  margin-top: 24px;
}

.history-performance-card {
  display: flex;
  min-height: 132px;
  align-items: flex-start;
  gap: 13px;
  border: 1px solid rgba(89, 225, 255, .14);
  border-radius: 18px;
  background: rgba(3, 10, 32, .62);
  padding: 18px;
}

.history-performance-icon {
  display: grid;
  width: 42px;
  height: 42px;
  flex: 0 0 auto;
  border-radius: 13px;
  background: rgba(0, 211, 255, .09);
  color: #67e6f7;
  place-items: center;
}

.history-performance-card span,
.history-performance-card strong,
.history-performance-card small {
  display: block;
}

.history-performance-card span {
  color: #83aab5;
  font-size: .72rem;
  font-weight: 800;
  letter-spacing: .04em;
  text-transform: uppercase;
}

.history-performance-card strong {
  margin-top: 9px;
  color: #fff;
  font-size: 1.45rem;
  line-height: 1.15;
}

.history-performance-card small {
  margin-top: 8px;
  color: #708f99;
  line-height: 1.35;
}

.history-performance-highlight {
  border-color: rgba(74, 222, 128, .24);
  background: linear-gradient(
    135deg,
    rgba(74, 222, 128, .08),
    rgba(3, 10, 32, .62)
  );
}

.history-performance-highlight .history-performance-icon,
.history-performance-verified .history-performance-icon {
  background: rgba(74, 222, 128, .1);
  color: #86efac;
}

.history-performance-highlight strong,
.history-performance-verified strong {
  color: #a7f3d0;
}

.history-verification-message {
  display: flex;
  align-items: center;
  gap: 9px;
  margin-top: 16px;
  border: 1px solid rgba(74, 222, 128, .24);
  border-radius: 14px;
  background: rgba(74, 222, 128, .07);
  color: #a7f3d0;
  padding: 12px 14px;
}

.history-state {
  display: flex;
  min-height: 130px;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-top: 18px;
  border: 1px dashed rgba(89, 225, 255, .18);
  border-radius: 18px;
  color: #9cc0ca;
}

.history-state-error {
  border-color: rgba(248, 113, 113, .3);
  color: #fecaca;
}

.history-spinner {
  animation: history-spin .8s linear infinite;
}

@keyframes history-spin {
  to {
    transform: rotate(360deg);
  }
}

.history-list-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18px;
  margin-top: 28px;
}

.history-list-heading h3 {
  margin: 0;
  color: #fff;
  font-size: 1.35rem;
}

.history-list-heading > span {
  color: #7799a4;
  font-size: .82rem;
}

.history-list {
  display: grid;
  gap: 12px;
  margin-top: 14px;
}

.history-item {
  overflow: hidden;
  border: 1px solid rgba(89, 225, 255, .13);
  border-radius: 18px;
  background: rgba(3, 10, 32, .62);
}

.history-item-summary {
  display: grid;
  width: 100%;
  grid-template-columns: auto 1.15fr 1fr 1fr auto auto;
  align-items: center;
  gap: 15px;
  border: 0;
  background: transparent;
  color: inherit;
  padding: 17px;
  text-align: left;
}

.history-item-summary:hover {
  background: rgba(0, 211, 255, .025);
}

.history-signal {
  display: grid;
  width: 42px;
  height: 42px;
  border-radius: 13px;
  place-items: center;
}

.history-signal-positive {
  background: rgba(74, 222, 128, .1);
  color: #86efac;
}

.history-signal-negative {
  background: rgba(248, 113, 113, .1);
  color: #fca5a5;
}

.history-signal-neutral {
  background: rgba(250, 204, 21, .1);
  color: #fde68a;
}

.history-symbol strong,
.history-recommendation strong,
.history-move strong {
  display: block;
  color: #fff;
}

.history-symbol span,
.history-recommendation span,
.history-move span {
  display: block;
  margin-top: 4px;
  color: #789aa5;
  font-size: .76rem;
}

.history-status {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border-radius: 999px;
  padding: 8px 10px;
  font-size: .72rem;
  font-weight: 800;
  white-space: nowrap;
}

.history-status-pending {
  border: 1px solid rgba(96, 216, 255, .22);
  background: rgba(96, 216, 255, .08);
  color: #83e6f6;
}

.history-status-due {
  border: 1px solid rgba(250, 204, 21, .28);
  background: rgba(250, 204, 21, .09);
  color: #fde68a;
}

.history-status-correct {
  border: 1px solid rgba(74, 222, 128, .32);
  background: rgba(74, 222, 128, .1);
  color: #86efac;
}

.history-status-incorrect {
  border: 1px solid rgba(248, 113, 113, .32);
  background: rgba(248, 113, 113, .1);
  color: #fca5a5;
}

.history-item-details {
  border-top: 1px solid rgba(89, 225, 255, .1);
  padding: 20px;
}

.saved-prediction-overview {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.saved-prediction-overview > div {
  border: 1px solid rgba(89, 225, 255, .12);
  border-radius: 15px;
  background: rgba(0, 211, 255, .035);
  padding: 15px;
}

.saved-prediction-overview span,
.saved-prediction-overview strong {
  display: block;
}

.saved-prediction-overview span {
  color: #7ea4af;
  font-size: .7rem;
  font-weight: 800;
  letter-spacing: .04em;
  text-transform: uppercase;
}

.saved-prediction-overview strong {
  margin-top: 7px;
  color: #fff;
  line-height: 1.35;
}

.saved-forecast-timeline {
  margin-top: 18px;
  border: 1px solid rgba(89, 225, 255, .12);
  border-radius: 18px;
  background: rgba(3, 10, 32, .45);
  padding: 18px;
}

.saved-forecast-timeline-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.saved-forecast-timeline-heading h4 {
  margin: 0;
  color: #fff;
  font-size: 1.15rem;
}

.saved-forecast-timeline-heading > svg {
  color: #68e7f7;
}

.saved-forecast-timeline-track {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr;
  align-items: center;
  gap: 12px;
  margin-top: 18px;
}

.timeline-step {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}

.timeline-marker {
  display: grid;
  width: 34px;
  height: 34px;
  flex: 0 0 auto;
  border-radius: 50%;
  place-items: center;
}

.timeline-step strong,
.timeline-step small {
  display: block;
}

.timeline-step strong {
  color: #fff;
  font-size: .86rem;
}

.timeline-step small {
  margin-top: 4px;
  color: #7799a4;
  font-size: .72rem;
  line-height: 1.35;
}

.timeline-step-complete .timeline-marker {
  background: rgba(74, 222, 128, .12);
  color: #86efac;
}

.timeline-step-active .timeline-marker {
  background: rgba(0, 211, 255, .12);
  color: #6ee7f8;
  box-shadow: 0 0 18px rgba(0, 211, 255, .16);
}

.timeline-step-upcoming .timeline-marker {
  background: rgba(125, 60, 255, .12);
  color: #c4b5fd;
}

.timeline-connector {
  width: 42px;
  height: 1px;
  background: linear-gradient(
    90deg,
    rgba(74, 222, 128, .45),
    rgba(0, 211, 255, .28)
  );
}

.saved-trajectory-block {
  margin-top: 18px;
}

.saved-trajectory-note {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
  margin-bottom: 12px;
  border-left: 3px solid #67e8ff;
  background: rgba(0, 211, 255, .05);
  padding: 12px 14px;
}

.saved-trajectory-note strong {
  color: #fff;
}

.saved-trajectory-note span {
  max-width: 720px;
  color: #8fb2bd;
  line-height: 1.5;
}

.history-item-details .forecast-trajectory-section {
  margin-top: 0;
}

.history-detail-metrics,
.verification-result-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
  margin-top: 18px;
}

.verification-result-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 14px;
}

.verification-result-grid article {
  display: grid;
  gap: 8px;
  border: 1px solid rgba(89, 225, 255, .14);
  border-radius: 17px;
  background: rgba(3, 10, 32, .62);
  padding: 17px;
}

.verification-result-grid svg {
  color: #67e6f7;
}

.verification-result-grid span {
  color: #83aab5;
  font-size: .75rem;
  font-weight: 800;
  text-transform: uppercase;
}

.verification-result-grid strong {
  color: #fff;
  font-size: 1.35rem;
}

.history-detail-metrics > div {
  border: 1px solid rgba(89, 225, 255, .11);
  border-radius: 14px;
  background: rgba(0, 211, 255, .035);
  padding: 14px;
}

.history-detail-metrics span,
.history-detail-metrics strong {
  display: block;
}

.history-detail-metrics span {
  color: #7ea4af;
  font-size: .72rem;
  font-weight: 800;
  text-transform: uppercase;
}

.history-detail-metrics strong {
  margin-top: 7px;
  color: #fff;
}

.history-explanation {
  margin: 16px 0 0;
  border-left: 3px solid #58e1f2;
  background: rgba(0, 211, 255, .05);
  color: #c6e7ed;
  padding: 14px 16px;
  line-height: 1.6;
}

.history-reasons-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
  margin-top: 16px;
}

.history-reasons-grid h4 {
  margin: 0;
  color: #fff;
}

.history-reasons-grid ul {
  display: grid;
  gap: 8px;
  margin: 10px 0 0;
  padding-left: 18px;
  color: #9abac4;
  line-height: 1.45;
}

@media (max-width: 1180px) {
  .history-performance-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .saved-prediction-overview {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 900px) {
  .history-section-heading {
    align-items: flex-start;
    flex-direction: column;
  }

  .history-heading-actions {
    width: 100%;
    justify-content: space-between;
  }

  .history-detail-metrics,
  .verification-result-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .history-item-summary {
    grid-template-columns: auto 1fr auto;
  }

  .history-recommendation,
  .history-move,
  .history-status {
    grid-column: 2 / -1;
  }

  .saved-forecast-timeline-track {
    grid-template-columns: 1fr;
  }

  .timeline-connector {
    width: 1px;
    height: 24px;
    margin-left: 16px;
  }

  .saved-trajectory-note {
    flex-direction: column;
  }
}

@media (max-width: 580px) {
  .prediction-history-section {
    padding: 22px 18px;
  }

  .history-heading-actions {
    align-items: stretch;
    flex-direction: column;
  }

  .history-verify-button {
    width: 100%;
  }

  .history-performance-grid,
  .history-detail-metrics,
  .verification-result-grid,
  .history-reasons-grid,
  .saved-prediction-overview {
    grid-template-columns: 1fr;
  }

  .history-list-heading {
    align-items: flex-start;
    flex-direction: column;
  }
}
