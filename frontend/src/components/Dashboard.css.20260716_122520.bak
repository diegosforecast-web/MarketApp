.dimarket-shell {
  display: grid;
  min-height: 100vh;
  grid-template-columns: 280px minmax(0, 1fr);
  gap: 24px;
  padding: 24px;
}

.dimarket-sidebar,
.welcome-experience-card,
.journey-card,
.forecast-workspace,
.empty-prediction-state,
.prediction-loading-card,
.prediction-overview,
.decision-grid article,
.explanation-section,
.historical-section,
.trust-section,
.plans-section,
.dashboard-highlight-card,
.forecast-refresh-reminder {
  border: 1px solid rgba(89, 225, 255, .2);
  background: rgba(5, 11, 38, .76);
  box-shadow:
    0 0 34px rgba(0, 210, 255, .08),
    inset 0 0 24px rgba(139, 61, 255, .035);
  backdrop-filter: blur(20px);
}

.dimarket-sidebar {
  position: sticky;
  top: 24px;
  display: flex;
  height: calc(100vh - 48px);
  min-height: 0;
  flex-direction: column;
  border-radius: 28px;
  padding: 20px 18px;
  overflow-y: auto;
  overflow-x: hidden;
  overscroll-behavior: contain;
  scrollbar-width: thin;
  scrollbar-color: rgba(99, 228, 247, .35) transparent;
}

.dimarket-sidebar::-webkit-scrollbar {
  width: 6px;
}

.dimarket-sidebar::-webkit-scrollbar-track {
  background: transparent;
}

.dimarket-sidebar::-webkit-scrollbar-thumb {
  border-radius: 999px;
  background: rgba(99, 228, 247, .35);
}

.sidebar-brand {
  flex: 0 0 auto;
  text-align: center;
  border-bottom: 1px solid rgba(102, 223, 255, .12);
  padding-bottom: 20px;
}

.sidebar-brand img {
  width: 180px;
  height: 132px;
  object-fit: contain;
  filter: drop-shadow(0 0 22px rgba(0, 226, 255, .38));
}

.sidebar-brand h2 {
  margin: -5px 0 3px;
  color: #fff;
}

.sidebar-brand span {
  color: #7dcddd;
  font-size: .72rem;
}

.sidebar-navigation {
  display: grid;
  flex: 0 0 auto;
  gap: 7px;
  margin-top: 22px;
}

.sidebar-link,
.sidebar-logout {
  display: flex;
  align-items: center;
  gap: 11px;
  border: 1px solid transparent;
  border-radius: 13px;
  background: transparent;
  color: #b7dce5;
  padding: 12px 13px;
  font-weight: 700;
}

.sidebar-link:hover,
.sidebar-link-active {
  border-color: rgba(74, 225, 255, .26);
  background: linear-gradient(
    90deg,
    rgba(0, 211, 255, .11),
    rgba(139, 61, 255, .07)
  );
  color: #fff;
}

.sidebar-account {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  gap: 11px;
  margin-top: auto;
  border: 1px solid rgba(102, 223, 255, .16);
  border-radius: 15px;
  background: rgba(10, 23, 55, .7);
  padding: 13px;
}

.sidebar-account strong,
.sidebar-account span {
  display: block;
  max-width: 170px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sidebar-account strong {
  color: #fff;
}

.sidebar-account span {
  margin-top: 3px;
  color: #87cbd8;
  font-size: .69rem;
}

.sidebar-logout {
  width: 100%;
  flex: 0 0 auto;
  margin-top: 10px;
}

.dimarket-main {
  display: grid;
  align-content: start;
  gap: 20px;
  min-width: 0;
}

.dashboard-eyebrow {
  display: block;
  margin-bottom: 9px;
  color: #63e4f7;
  font-size: .73rem;
  font-weight: 900;
  letter-spacing: .18em;
}

.welcome-experience-card {
  display: grid;
  grid-template-columns: 1.35fr .65fr;
  gap: 28px;
  border-radius: 30px;
  padding: 42px;
  overflow: hidden;
  background:
    radial-gradient(circle at 10% 0, rgba(0, 220, 255, .15), transparent 35%),
    radial-gradient(circle at 100% 100%, rgba(139, 61, 255, .2), transparent 40%),
    rgba(5, 11, 38, .78);
}

.welcome-kicker {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: 1px solid rgba(103, 232, 255, .25);
  border-radius: 999px;
  background: rgba(0, 211, 255, .06);
  color: #70e8f8;
  padding: 8px 12px;
  font-size: .72rem;
  font-weight: 900;
  letter-spacing: .15em;
}

.welcome-copy h1 {
  margin: 22px 0 16px;
  color: #fff;
  font-size: clamp(2.3rem, 4vw, 4.1rem);
  line-height: 1.02;
}

.welcome-copy p {
  color: #abcbd3;
  font-size: 1.06rem;
  line-height: 1.7;
}

.welcome-copy strong {
  color: #fff;
}

.welcome-philosophy {
  color: #69e3f3 !important;
  font-weight: 800;
}

.welcome-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 10px;
  border-radius: 14px;
  background: linear-gradient(90deg, #00cceb, #853cff);
  color: #fff;
  padding: 13px 17px;
  font-weight: 900;
}

.welcome-credit-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(105, 231, 255, .23);
  border-radius: 24px;
  background: rgba(3, 9, 32, .7);
  padding: 28px 22px;
  text-align: center;
}

.welcome-credit-icon {
  display: grid;
  width: 58px;
  height: 58px;
  border-radius: 18px;
  background: linear-gradient(135deg, #00cceb, #7f3cff);
  place-items: center;
}

.welcome-credit-card > span {
  margin-top: 17px;
  color: #72dfed;
  font-size: .69rem;
  font-weight: 900;
  letter-spacing: .14em;
}

.premium-stars {
  display: flex;
  gap: 7px;
  margin: 16px 0 12px;
  color: #f7d85d;
}

.welcome-credit-card strong {
  color: #fff;
}

.welcome-credit-card p {
  color: #86aab5;
  font-size: .83rem;
}

.journey-grid {
  display: grid;
  grid-template-columns: 1.2fr .8fr .8fr;
  gap: 16px;
}

.journey-card {
  min-height: 230px;
  border-radius: 22px;
  padding: 24px;
}

.journey-card h2 {
  margin: 0;
  color: #fff;
  font-size: 1.7rem;
}

.journey-card > p {
  color: #94b5bf;
  line-height: 1.55;
}

.journey-steps {
  display: grid;
  gap: 12px;
  margin-top: 22px;
}

.journey-steps span {
  display: flex;
  align-items: center;
  gap: 10px;
  color: #c2edf3;
}

.journey-steps svg {
  color: #76e9a0;
}

.journey-pending {
  color: #718e98 !important;
}

.journey-pending svg {
  color: #718e98;
}

.journey-next,
.usage-footer {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-top: 20px;
  border-top: 1px solid rgba(102, 223, 255, .1);
  padding-top: 16px;
  color: #7999a4;
}

.journey-next strong,
.usage-footer strong {
  color: #75e5f4;
}

.usage-value {
  display: flex;
  align-items: baseline;
  gap: 8px;
  margin-top: 22px;
}

.usage-value strong {
  color: #fff;
  font-size: 2.6rem;
}

.usage-value span {
  color: #8daeb8;
}

.usage-track {
  height: 10px;
  margin-top: 22px;
  border-radius: 999px;
  background: rgba(76, 104, 132, .23);
  overflow: hidden;
}

.usage-track div {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #00d1e8, #7e3cff);
  transition: width .45s ease;
}

.experience-points {
  display: grid;
  gap: 9px;
  margin-top: 18px;
}

.experience-points span {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #b5d6de;
  font-size: .86rem;
}

.experience-points svg {
  color: #74e7a0;
}

.forecast-workspace {
  display: grid;
  grid-template-columns: .85fr 1.35fr;
  gap: 32px;
  border-radius: 26px;
  padding: 30px;
}

.forecast-workspace h2,
.empty-prediction-state h2,
.prediction-loading-card h2,
.prediction-title-block h2,
.section-heading h2 {
  margin: 0;
  color: #fff;
}

.forecast-workspace p,
.empty-prediction-state p,
.prediction-loading-card p {
  color: #95b7c2;
  line-height: 1.55;
}

.forecast-form {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  align-items: end;
}

.forecast-form label {
  display: grid;
  gap: 8px;
  color: #c8f3fb;
  font-size: .84rem;
  font-weight: 800;
}

.forecast-control {
  display: flex;
  min-height: 56px;
  align-items: center;
  gap: 10px;
  border: 1px solid rgba(82, 221, 255, .22);
  border-radius: 14px;
  background: rgba(2, 8, 29, .78);
  padding: 0 15px;
}

.forecast-control input,
.forecast-control select {
  width: 100%;
  border: 0;
  outline: 0;
  background: transparent;
  color: #fff;
  padding: 14px 0;
}

.forecast-control option {
  background: #07102d;
}

.run-forecast-button {
  display: flex;
  min-height: 58px;
  grid-column: 1 / -1;
  align-items: center;
  justify-content: center;
  gap: 9px;
  border: 0;
  border-radius: 15px;
  background: linear-gradient(90deg, #00cceb, #873dff);
  color: #fff;
  font-weight: 900;
}

.dashboard-alert {
  display: flex;
  grid-column: 1 / -1;
  align-items: center;
  gap: 10px;
  border: 1px solid rgba(248, 113, 113, .38);
  border-radius: 13px;
  background: rgba(248, 113, 113, .09);
  color: #fecaca;
  padding: 12px 14px;
}

.empty-prediction-state,
.prediction-loading-card {
  display: flex;
  align-items: center;
  gap: 22px;
  border-radius: 24px;
  padding: 30px;
}

.empty-prediction-state > svg {
  color: #62e6f7;
}

.prediction-loader {
  width: 52px;
  height: 52px;
  border: 4px solid rgba(92, 225, 255, .15);
  border-top-color: #58e6ff;
  border-radius: 50%;
  animation: spin .85s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.prediction-overview,
.explanation-section,
.historical-section,
.trust-section,
.plans-section,
.dashboard-highlight-card,
.forecast-refresh-reminder {
  border-radius: 26px;
  padding: 30px;
}

.prediction-title-block,
.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22px;
}

.prediction-title-block h2 {
  font-size: 2.35rem;
}

.prediction-title-block p {
  color: #8fb2bd;
}

.recommendation-badge {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  border-radius: 999px;
  padding: 13px 18px;
  font-weight: 900;
}

.recommendation-positive {
  border: 1px solid rgba(74, 222, 128, .42);
  background: rgba(74, 222, 128, .1);
  color: #86efac;
}

.recommendation-negative {
  border: 1px solid rgba(248, 113, 113, .42);
  background: rgba(248, 113, 113, .09);
  color: #fca5a5;
}

.recommendation-neutral {
  border: 1px solid rgba(250, 204, 21, .42);
  background: rgba(250, 204, 21, .09);
  color: #fde68a;
}

.prediction-main-grid {
  display: grid;
  grid-template-columns: 1.45fr .75fr;
  gap: 18px;
  margin-top: 24px;
}

.prediction-metrics-grid,
.historical-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.metric-card {
  display: flex;
  min-height: 128px;
  gap: 13px;
  border: 1px solid rgba(90, 220, 255, .14);
  border-radius: 18px;
  background: rgba(3, 10, 32, .62);
  padding: 18px;
}

.metric-icon {
  display: grid;
  width: 40px;
  height: 40px;
  flex: 0 0 auto;
  border-radius: 12px;
  background: rgba(0, 211, 255, .09);
  color: #65e5f6;
  place-items: center;
}

.metric-card span,
.metric-card strong,
.metric-card small {
  display: block;
}

.metric-card span {
  color: #89b8c4;
  font-size: .73rem;
  font-weight: 800;
  text-transform: uppercase;
}

.metric-card strong {
  margin-top: 9px;
  color: #fff;
  font-size: 1.45rem;
}

.metric-card small {
  margin-top: 7px;
  color: #748f99;
}

.metric-positive strong {
  color: #86efac;
}

.metric-negative strong {
  color: #fca5a5;
}

.confidence-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(87, 223, 255, .15);
  border-radius: 20px;
  background: rgba(3, 10, 32, .64);
  padding: 22px;
  text-align: center;
}

.confidence-gauge {
  display: grid;
  width: 168px;
  height: 168px;
  border-radius: 50%;
  background:
    radial-gradient(circle at center, #08112f 58%, transparent 59%),
    conic-gradient(
      #00d9ef 0deg,
      #7d3cff var(--confidence),
      rgba(67, 91, 127, .2) var(--confidence),
      rgba(67, 91, 127, .2) 360deg
    );
  place-items: center;
}

.confidence-gauge strong,
.confidence-gauge span {
  display: block;
  text-align: center;
}

.confidence-gauge strong {
  color: #fff;
  font-size: 2.2rem;
}

.confidence-gauge span {
  color: #6ee7f8;
  font-size: .72rem;
  font-weight: 900;
}

.confidence-panel p {
  color: #8dacb7;
}

.decision-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}

.decision-grid article {
  border-radius: 22px;
  padding: 23px;
}

.decision-grid h3 {
  color: #fff;
}

.decision-grid li {
  color: #a6c4cd;
  line-height: 1.5;
}

.explanation-summary {
  border-left: 3px solid #54deef;
  background: rgba(0, 211, 255, .055);
  color: #c9e8ee;
  line-height: 1.65;
  padding: 15px 17px;
}

.driver-columns {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.driver-columns h3 {
  display: flex;
  align-items: center;
  gap: 9px;
  color: #fff;
}

.driver-card {
  margin-bottom: 12px;
  border: 1px solid rgba(83, 220, 255, .13);
  border-radius: 17px;
  background: rgba(3, 10, 32, .62);
  padding: 17px;
}

.driver-card strong {
  color: #fff;
}

.driver-card p {
  color: #8eabb5;
  font-size: .85rem;
}

.driver-card span {
  color: #cdeef4;
}

.historical-metrics {
  grid-template-columns: repeat(4, minmax(0, 1fr));
  margin-top: 22px;
}

.trust-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  margin-top: 22px;
}

.trust-grid article {
  display: flex;
  gap: 11px;
  border: 1px solid rgba(88, 224, 255, .13);
  border-radius: 17px;
  background: rgba(3, 10, 32, .58);
  padding: 17px;
}

.trust-grid svg {
  color: #73e69e;
}

.trust-grid strong {
  color: #fff;
}

.trust-grid p {
  color: #88a8b2;
  font-size: .84rem;
}

.trust-section blockquote {
  margin: 24px 0 0;
  border-left: 3px solid #74e4f3;
  background: rgba(0, 211, 255, .05);
  color: #c6e7ed;
  padding: 16px 18px;
  line-height: 1.6;
}

.plan-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 15px;
  margin-top: 24px;
}

.plan-card {
  display: flex;
  min-height: 390px;
  flex-direction: column;
  border: 1px solid rgba(89, 223, 255, .14);
  border-radius: 21px;
  background: rgba(3, 10, 32, .62);
  padding: 22px;
}

.plan-card h3 {
  margin: 18px 0 6px;
  color: #fff;
  font-size: 1.55rem;
}

.plan-card > p {
  color: #93b4be;
}

.plan-card ul {
  display: grid;
  gap: 11px;
  margin: 22px 0;
  padding: 0;
  list-style: none;
}

.plan-card li {
  display: flex;
  gap: 8px;
  color: #b4d1d8;
  font-size: .84rem;
}

.plan-card li svg {
  color: #73e49d;
}

.plan-card button {
  display: flex;
  min-height: 48px;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: auto;
  border: 1px solid rgba(87, 225, 255, .2);
  border-radius: 13px;
  background: rgba(0, 211, 255, .06);
  color: #c9f7fc;
  font-weight: 800;
}

.plan-premium button,
.plan-gold button {
  border: 0;
  background: linear-gradient(90deg, #00cceb, #7e3cff);
  color: #fff;
}

.current-plan-label {
  width: fit-content;
  border-radius: 999px;
  background: rgba(0, 211, 255, .1);
  color: #72e5f4;
  padding: 7px 10px;
  font-size: .65rem;
  font-weight: 900;
}

.plan-current {
  box-shadow: 0 0 24px rgba(0, 211, 255, .1);
}

.sidebar-section-label {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin: 22px 8px 8px;
  border-top: 1px solid rgba(103, 232, 255, 0.14);
  border-bottom: 1px solid rgba(103, 232, 255, 0.14);
  background: linear-gradient(
    90deg,
    transparent,
    rgba(0, 211, 255, 0.08),
    transparent
  );
  color: #67e8ff;
  padding: 12px 8px;
  font-size: 0.92rem;
  font-weight: 900;
  letter-spacing: 0.2em;
  text-align: center;
  text-shadow:
    0 0 10px rgba(103, 232, 255, 0.45),
    0 0 22px rgba(0, 211, 255, 0.2);
}

.sidebar-section-arrow {
  display: inline-block;
  color: #84cc16;
  font-size: 1.25rem;
  line-height: 1;
  animation: sidebar-arrow-bounce 1.35s ease-in-out infinite;
}

@keyframes sidebar-arrow-bounce {
  0%,
  100% {
    transform: translateY(-2px);
  }

  50% {
    transform: translateY(4px);
  }
}

.sidebar-navigation { margin-top: 8px; }

.dashboard-highlight-grid {
  display: grid;
  grid-template-columns: 1.2fr 1fr .8fr;
  gap: 16px;
}

.dashboard-highlight-card {
  display: flex;
  min-height: 220px;
  gap: 16px;
  border-radius: 22px;
  padding: 24px;
}

.dashboard-highlight-card h2 {
  margin: 0;
  color: #fff;
  font-size: 1.45rem;
  line-height: 1.2;
}

.dashboard-highlight-card p {
  color: #8eafb9;
  line-height: 1.55;
}

.dashboard-highlight-icon,
.forecast-refresh-reminder-icon {
  display: grid;
  width: 48px;
  height: 48px;
  flex: 0 0 auto;
  border-radius: 15px;
  background: linear-gradient(135deg, rgba(0, 204, 235, .18), rgba(126, 60, 255, .20));
  color: #71e8f8;
  place-items: center;
}

.dashboard-status-pill {
  display: inline-flex;
  border: 1px solid rgba(103, 232, 255, .22);
  border-radius: 999px;
  background: rgba(0, 211, 255, .07);
  color: #77e5f5;
  padding: 7px 10px;
  font-size: .7rem;
  font-weight: 900;
}

.dashboard-improvement-list {
  display: grid;
  gap: 12px;
  margin: 18px 0 0;
  padding: 0;
  list-style: none;
}

.dashboard-improvement-list li {
  display: flex;
  align-items: center;
  gap: 9px;
  color: #b9dbe2;
}

.dashboard-improvement-list svg { color: #75e7a0; }

.community-rating-stars {
  display: flex;
  gap: 5px;
  margin-top: 16px;
  color: #54717b;
}

.forecast-refresh-reminder {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: start;
  gap: 16px;
  border-radius: 20px;
  padding: 20px 22px;
}

.forecast-refresh-reminder strong {
  display: block;
  color: #eefcff;
}

.forecast-refresh-reminder p {
  margin: 8px 0 0;
  color: #91b4be;
  line-height: 1.55;
}

.forecast-refresh-reminder > button {
  display: grid;
  border: 0;
  background: transparent;
  color: #79cbd7;
  padding: 4px;
  place-items: center;
}
@media (max-width: 1180px) {
  .dimarket-shell {
    grid-template-columns: 235px minmax(0, 1fr);
  }

  .welcome-experience-card,
  .forecast-workspace,
  .prediction-main-grid {
    grid-template-columns: 1fr;
  }

  .journey-grid,
  .trust-grid,
  .dashboard-highlight-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .plan-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .historical-metrics {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 860px) {
  .dimarket-shell {
    grid-template-columns: 1fr;
    padding: 14px;
  }

  .dimarket-sidebar {
    position: static;
    height: auto;
    max-height: none;
    overflow: visible;
  }

  .sidebar-navigation {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .sidebar-account {
    margin-top: 18px;
  }

  .journey-grid,
  .dashboard-highlight-grid,
  .decision-grid,
  .driver-columns,
  .trust-grid {
    grid-template-columns: 1fr;
  }

  .prediction-title-block,
  .section-heading {
    align-items: flex-start;
    flex-direction: column;
  }
}

@media (max-width: 580px) {
  .sidebar-navigation,
  .forecast-form,
  .prediction-metrics-grid,
  .historical-metrics,
  .plan-grid {
    grid-template-columns: 1fr;
  }

  .welcome-experience-card,
  .forecast-workspace,
  .prediction-overview,
  .explanation-section,
  .historical-section,
  .trust-section,
.plans-section,
.dashboard-highlight-card,
.forecast-refresh-reminder {
    padding: 22px 18px;
  }

  .empty-prediction-state,
  .prediction-loading-card {
    align-items: flex-start;
    flex-direction: column;
  }
}



/* Sprint 5 Plans */
.forecast-warning-backdrop {
  position: fixed;
  z-index: 1000;
  inset: 0;
  display: grid;
  place-items: center;
  background: rgba(1, 5, 20, .76);
  padding: 20px;
  backdrop-filter: blur(10px);
}

.forecast-warning-dialog {
  display: grid;
  width: min(100%, 620px);
  grid-template-columns: auto 1fr;
  gap: 18px;
  border: 1px solid rgba(250, 204, 21, .34);
  border-radius: 24px;
  background: rgba(5, 11, 38, .97);
  box-shadow: 0 24px 80px rgba(0, 0, 0, .48);
  padding: 26px;
}

.forecast-warning-icon {
  display: grid;
  width: 54px;
  height: 54px;
  border-radius: 16px;
  background: rgba(250, 204, 21, .11);
  color: #fde68a;
  place-items: center;
}

.forecast-warning-dialog h2 {
  margin: 0;
  color: #fff;
}

.forecast-warning-dialog p {
  margin: 12px 0 0;
  color: #9fbcc5;
  line-height: 1.65;
}

.forecast-warning-actions {
  display: flex;
  grid-column: 1 / -1;
  justify-content: flex-end;
  gap: 10px;
}

.forecast-warning-actions button {
  display: inline-flex;
  min-height: 48px;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border-radius: 13px;
  padding: 0 16px;
  font-weight: 900;
}

.forecast-warning-cancel {
  border: 1px solid rgba(89, 225, 255, .2);
  background: rgba(0, 211, 255, .05);
  color: #b8e8ef;
}

.forecast-warning-confirm {
  border: 0;
  background: linear-gradient(90deg, #00cceb, #873dff);
  color: #fff;
}

.extended-confidence-banner {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  border: 1px solid rgba(250, 204, 21, .28);
  border-radius: 20px;
  background: rgba(250, 204, 21, .06);
  padding: 20px 22px;
}

.extended-confidence-banner > svg {
  flex: 0 0 auto;
  color: #fde68a;
}

.extended-confidence-banner strong {
  display: block;
  color: #fff;
}

.extended-confidence-banner p {
  margin: 7px 0 0;
  color: #94b4be;
  line-height: 1.55;
}

.plan-card-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-top: 16px;
}

.plan-card-heading h3 {
  margin: 0;
}

.plan-card-heading p {
  margin: 7px 0 0;
  color: #93b4be;
}

.plan-price {
  flex: 0 0 auto;
  color: #fff;
  font-size: .96rem;
  text-align: right;
}

.plan-gold .plan-price {
  color: #fde68a;
  font-size: 1.12rem;
}

.plan-access-summary {
  margin-top: 18px;
  border: 1px solid rgba(89, 225, 255, .12);
  border-radius: 13px;
  background: rgba(0, 211, 255, .04);
  color: #b9e3ea;
  padding: 12px;
  font-size: .82rem;
  font-weight: 800;
  line-height: 1.45;
}

@media (max-width: 580px) {
  .forecast-warning-dialog {
    grid-template-columns: 1fr;
  }

  .forecast-warning-actions {
    grid-column: 1;
    flex-direction: column-reverse;
  }

  .forecast-warning-actions button {
    width: 100%;
  }

  .plan-card-heading {
    flex-direction: column;
  }

  .plan-price {
    text-align: left;
  }
}


html{scroll-behavior:smooth}
#welcome,#standard,#forecast,#watchlist,#portfolio,#performance,#journey,#community,#settings,#plans{scroll-margin-top:24px}
.welcome-plan-premium{border-color:rgba(192,132,252,.38)}
.welcome-plan-gold{border-color:rgba(250,204,21,.42);background:radial-gradient(circle at 50% 0,rgba(250,204,21,.12),transparent 45%),rgba(3,9,32,.72)}

/* =========================================================
   Dashboard premium polish
   ========================================================= */
.dimarket-shell { max-width: 1680px; margin: 0 auto; gap: 24px; padding: 24px; }
.dimarket-main { gap: 24px; }
.dimarket-main > * { animation: dm-section-enter var(--dm-slow) var(--dm-ease) both; }
.dimarket-main > *:nth-child(2) { animation-delay: 35ms; }
.dimarket-main > *:nth-child(3) { animation-delay: 70ms; }
.dimarket-main > *:nth-child(4) { animation-delay: 105ms; }
.dimarket-sidebar,
.welcome-experience-card,
.journey-card,
.forecast-workspace,
.empty-prediction-state,
.prediction-loading-card,
.prediction-overview,
.decision-grid article,
.explanation-section,
.historical-section,
.trust-section,
.plans-section,
.dashboard-highlight-card,
.forecast-refresh-reminder {
  border-color: var(--dm-border);
  box-shadow: var(--dm-shadow-md);
}
.dimarket-sidebar { background: linear-gradient(180deg, rgba(8, 17, 48, .92), rgba(4, 9, 31, .84)); }
.sidebar-brand img { transition: transform var(--dm-normal) var(--dm-ease), filter var(--dm-normal) var(--dm-ease); }
.sidebar-brand img:hover { transform: translateY(-2px) scale(1.015); }
.sidebar-link, .sidebar-logout {
  transition: transform var(--dm-fast) var(--dm-ease), border-color var(--dm-fast) var(--dm-ease), background var(--dm-fast) var(--dm-ease), color var(--dm-fast) var(--dm-ease), box-shadow var(--dm-fast) var(--dm-ease);
}
.sidebar-link:hover, .sidebar-link-active { transform: translateX(4px); box-shadow: inset 3px 0 0 var(--dm-cyan); }
.sidebar-logout:hover { transform: translateX(3px); color: #fff; }
.sidebar-account { box-shadow: var(--dm-shadow-sm); }
.dashboard-eyebrow { color: var(--dm-cyan); text-transform: uppercase; line-height: 1.3; }
.section-heading h2, .forecast-workspace h2, .empty-prediction-state h2, .prediction-loading-card h2, .prediction-title-block h2 { letter-spacing: -.02em; line-height: 1.12; }
.welcome-experience-card { min-height: 340px; align-items: center; box-shadow: var(--dm-shadow-md), 0 0 60px rgba(0, 211, 255, .07); }
.welcome-copy h1 { max-width: 780px; letter-spacing: -.045em; }
.welcome-cta, .run-forecast-button, .plan-card button, .forecast-warning-actions button {
  transition: transform var(--dm-fast) var(--dm-ease), box-shadow var(--dm-fast) var(--dm-ease), filter var(--dm-fast) var(--dm-ease);
}
.welcome-cta:hover, .run-forecast-button:hover:not(:disabled), .plan-card button:hover:not(:disabled), .forecast-warning-actions button:hover:not(:disabled) {
  transform: translateY(-2px);
  filter: brightness(1.04);
  box-shadow: 0 12px 28px rgba(0, 204, 235, .16), 0 0 26px rgba(135, 61, 255, .14);
}
.welcome-cta:active, .run-forecast-button:active:not(:disabled), .plan-card button:active:not(:disabled) { transform: translateY(0); }
.journey-card, .metric-card, .driver-card, .trust-grid article, .plan-card, .dashboard-highlight-card, .decision-grid article {
  transition: transform var(--dm-normal) var(--dm-ease), border-color var(--dm-normal) var(--dm-ease), background var(--dm-normal) var(--dm-ease), box-shadow var(--dm-normal) var(--dm-ease);
}
.journey-card:hover, .metric-card:hover, .driver-card:hover, .trust-grid article:hover, .plan-card:hover, .dashboard-highlight-card:hover, .decision-grid article:hover {
  transform: translateY(-3px);
  border-color: var(--dm-border-strong);
  box-shadow: var(--dm-shadow-glow);
}
.forecast-control { transition: border-color var(--dm-fast) var(--dm-ease), box-shadow var(--dm-fast) var(--dm-ease), background var(--dm-fast) var(--dm-ease); }
.forecast-control:hover { border-color: rgba(82, 221, 255, .4); }
.forecast-control:focus-within { border-color: var(--dm-cyan); box-shadow: 0 0 0 4px rgba(99, 228, 247, .08), 0 0 24px rgba(0, 211, 255, .1); background: rgba(3, 10, 32, .92); }
.empty-prediction-state { border-style: dashed; background: linear-gradient(135deg, rgba(0, 211, 255, .035), rgba(135, 61, 255, .025)), rgba(5, 11, 38, .72); }
.prediction-loading-card { overflow: hidden; position: relative; }
.prediction-loading-card::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(105deg, transparent 30%, rgba(255, 255, 255, .035) 45%, transparent 60%);
  background-size: 220% 100%;
  animation: dm-shimmer 1.8s linear infinite;
  pointer-events: none;
}
.metric-card strong, .usage-value strong, .confidence-gauge strong, .plan-price { font-variant-numeric: tabular-nums; }
.recommendation-badge { box-shadow: 0 0 24px rgba(0, 0, 0, .12); }
.recommendation-positive { box-shadow: 0 0 22px rgba(74, 222, 128, .09); }
.recommendation-negative { box-shadow: 0 0 22px rgba(248, 113, 113, .09); }
.recommendation-neutral { box-shadow: 0 0 22px rgba(250, 204, 21, .08); }
.confidence-gauge { transition: transform var(--dm-normal) var(--dm-ease); }
.confidence-gauge:hover { transform: scale(1.025); }
.plan-card { overflow: hidden; position: relative; }
.plan-card::before { content: ""; position: absolute; inset: 0 auto 0 0; width: 3px; opacity: .8; background: linear-gradient(180deg, var(--dm-cyan), var(--dm-violet)); }
.plan-gold::before { background: linear-gradient(180deg, #fde68a, #f59e0b); }
.plan-current { border-color: rgba(99, 228, 247, .34); }
.current-plan-label { box-shadow: 0 0 18px rgba(0, 211, 255, .08); }
.dashboard-alert { animation: dm-fade-up var(--dm-normal) var(--dm-ease) both; }
@keyframes dm-section-enter { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
@media (max-width: 860px) {
  .dimarket-shell { padding: 14px; }
  .sidebar-link:hover, .sidebar-link-active { transform: translateY(-1px); }
}
@media (max-width: 580px) {
  .dimarket-main { gap: 16px; }
  .welcome-experience-card, .forecast-workspace, .prediction-overview, .explanation-section, .historical-section, .trust-section, .plans-section, .dashboard-highlight-card, .forecast-refresh-reminder { border-radius: 20px; }
  .welcome-copy h1 { font-size: clamp(2rem, 12vw, 3rem); }
  .section-heading h2, .forecast-workspace h2, .empty-prediction-state h2, .prediction-loading-card h2 { font-size: clamp(1.35rem, 7vw, 1.85rem); }
}

/* Mobile sidebar brand alignment */

.sidebar-brand img {
  display: block;
  margin-left: auto;
  margin-right: auto;
}

.sidebar-brand > span {
  display: block;
  width: 100%;
  margin-top: 4px;
  text-align: center;
  line-height: 1.4;
}

@media (max-width: 860px) {
  .sidebar-brand img {
    width: min(180px, 72vw);
    height: auto;
  }

  .sidebar-brand > span {
    max-width: 220px;
    margin-left: auto;
    margin-right: auto;
  }
}